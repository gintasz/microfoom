#!/bin/sh
# Repo-managed git hook. Tracked source lives in .githooks/; `prepare` (via
# scripts/install-hooks.mjs) copies it into the shared git hooks dir on every
# `pnpm install`, overwriting lefthook's generated template. That template ends its
# binary-discovery chain at a `mint` fallback which breaks fresh worktrees (no
# node_modules). We own the hook instead: bootstrap deps, then run the lefthook tiers.
set -e
dir="$(git rev-parse --show-toplevel)"
cd "$dir"
if [ ! -d node_modules/lefthook ] && [ ! -x node_modules/.bin/lefthook ]; then
  echo "microfoom: node_modules missing — bootstrapping (corepack pnpm install)…" >&2
  corepack pnpm install --frozen-lockfile
fi
exec corepack pnpm exec lefthook run pre-commit "$@"
