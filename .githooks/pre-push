#!/bin/sh
# Repo-managed git hook — see .githooks/pre-commit for the why. Bootstraps a fresh
# worktree's node_modules, then runs the full pre-push DoD tier via local lefthook.
set -e
dir="$(git rev-parse --show-toplevel)"
cd "$dir"
if [ ! -d node_modules/lefthook ] && [ ! -x node_modules/.bin/lefthook ]; then
  echo "microfoom: node_modules missing — bootstrapping (corepack pnpm install)…" >&2
  corepack pnpm install --frozen-lockfile
fi
exec corepack pnpm exec lefthook run pre-push "$@"
